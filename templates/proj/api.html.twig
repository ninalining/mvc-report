{% extends "proj/base_proj.html.twig" %}

{% block title %}Black Jack — API{% endblock %}

{% block body %}
<div class="proj-api">
    <h1>Black Jack JSON API</h1>
    <p>Testa API:et direkt från denna sida. Alla endpoints returnerar JSON.</p>

    {# === POST /proj/api/game/start === #}
    <div class="api-route">
        <h3><span class="method post">POST</span> /proj/api/game/start</h3>
        <p>Starta ett nytt spel. Skicka spelarnamn, insats och antal händer.</p>
        <form method="post" action="{{ path('proj_api_game_start') }}" target="_blank">
            <div class="proj-form" style="max-width: 100%; margin: 0;">
                <label for="api-start-name">Spelarnamn</label>
                <input type="text" id="api-start-name" name="playerName" value="TestPlayer" required>
                <label for="api-start-bet">Insats</label>
                <input type="number" id="api-start-bet" name="bet" value="10" min="1">
                <label for="api-start-hands">Antal händer</label>
                <input type="number" id="api-start-hands" name="hands" value="1" min="1" max="3">
                <button type="submit" class="proj-btn-gold">Testa</button>
            </div>
        </form>
    </div>

    {# === POST /proj/api/game/hit === #}
    <div class="api-route">
        <h3><span class="method post">POST</span> /proj/api/game/hit</h3>
        <p>Ta ett kort på den aktiva handen. Kräver ett pågående spel (starta först).</p>
        <form method="post" action="{{ path('proj_api_game_hit') }}" target="_blank">
            <button type="submit" class="proj-btn-gold">Testa</button>
        </form>
    </div>

    {# === POST /proj/api/game/stand === #}
    <div class="api-route">
        <h3><span class="method post">POST</span> /proj/api/game/stand</h3>
        <p>Stanna på den aktiva handen. Kräver ett pågående spel.</p>
        <form method="post" action="{{ path('proj_api_game_stand') }}" target="_blank">
            <button type="submit" class="proj-btn-gold">Testa</button>
        </form>
    </div>

    {# === GET /proj/api/game/status === #}
    <div class="api-route">
        <h3><span class="method get">GET</span> /proj/api/game/status</h3>
        <p>Visa status för det pågående spelet.</p>
        <a href="{{ path('proj_api_game_status') }}" target="_blank" class="proj-btn-green">Testa</a>
    </div>

    {# === GET /proj/api/player/{name}/stats === #}
    <div class="api-route">
        <h3><span class="method get">GET</span> /proj/api/player/{name}/stats</h3>
        <p>Visa statistik för en spelare. Ange spelarnamn nedan.</p>
        <div class="proj-form" style="max-width: 100%; margin: 0;">
            <label for="api-stats-name">Spelarnamn</label>
            <input type="text" id="api-stats-name" value="TestPlayer">
            <button class="proj-btn-green" onclick="window.open('/proj/api/player/' + encodeURIComponent(document.getElementById('api-stats-name').value) + '/stats', '_blank')">Testa</button>
        </div>
    </div>
</div>
{% endblock %}
