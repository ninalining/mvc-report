{% extends "proj/base_proj.html.twig" %}

{% block title %}Black Jack — Satsa{% endblock %}

{% block body %}
<div class="proj-landing">
    <h1>Placera din insats</h1>

    <div class="bj-info-bar">
        <span class="player-name">{{ playerName }}</span>
        <span class="balance">Saldo: {{ balance }} kr</span>
    </div>

    <form method="post" action="{{ path('proj_blackjack_deal') }}" class="proj-form">
        <label for="bet">Insats per hand (kr)</label>
        <input type="number" id="bet" name="bet" required
               min="1" max="{{ balance }}" value="10">

        <label for="hands">Antal händer (1–3)</label>
        <input type="number" id="hands" name="hands" required
               min="1" max="3" value="1">

        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" name="aiEnabled" value="1">
            Aktivera AI-motspelare
        </label>

        <button type="submit" class="proj-btn-gold" style="width: 100%;">Dela ut kort</button>
    </form>
</div>
{% endblock %}
