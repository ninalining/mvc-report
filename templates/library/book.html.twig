{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
<div class="library">
    <h1>{{ book.title }}</h1>

    <div class="book-detail">
        <img src="{{ asset('img/' ~ book.image) }}" alt="{{ book.title }}" class="book-cover">
        <div class="book-info">
            <p><strong>Författare:</strong> {{ book.author }}</p>
            <p><strong>ISBN:</strong> {{ book.isbn }}</p>
        </div>
    </div>

    <div class="library-actions">
        <a href="{{ path('library_edit', {id: book.id}) }}" class="btn">Redigera</a>
        <form action="{{ path('library_delete', {id: book.id}) }}" method="post" style="display:inline;">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Vill du verkligen ta bort denna bok?')">Ta bort</button>
        </form>
        <a href="{{ path('library_books') }}" class="btn">Tillbaka till alla böcker</a>
    </div>
</div>
{% endblock %}
